# Stack Auth
# Get these from your Stack Auth project dashboard, or from ~/.secrets/cmuxterm.env
NEXT_PUBLIC_STACK_PROJECT_ID=
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=
STACK_SECRET_SERVER_KEY=

# Resend (email)
RESEND_API_KEY=
CMUX_FEEDBACK_FROM_EMAIL=
CMUX_FEEDBACK_RATE_LIMIT_ID=

# Daemon -> APNs push bridge
# Shared bearer used by the Zig daemon to POST /api/notifications/push
CMUX_DAEMON_PUSH_SECRET=
# APNs credentials. Leave APNS_TEAM_ID or APNS_PRIVATE_KEY_* unset for dev mode.
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_PRIVATE_KEY_BASE64=
APNS_PRIVATE_KEY_PATH=
APNS_BUNDLE_ID=ai.manaflow.cmux
APNS_PRODUCTION=
