# Stack Auth
NEXT_PUBLIC_STACK_PROJECT_ID=
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=
STACK_SECRET_SERVER_KEY=

# Resend (email)
RESEND_API_KEY=
CMUX_FEEDBACK_FROM_EMAIL=
CMUX_FEEDBACK_RATE_LIMIT_ID=

# Daemon push notifications shared bearer (used by the Zig daemon to POST
# to /api/notifications/push)
CMUX_DAEMON_PUSH_SECRET=

# APNs (iOS push). Leave APNS_TEAM_ID and APNS_PRIVATE_KEY_* unset to run the
# push endpoint in dev mode (logs payload, does not call Apple).
APNS_TEAM_ID=
APNS_KEY_ID=
# Supply the .p8 key as base64 OR a filesystem path. Set at most one.
APNS_PRIVATE_KEY_BASE64=
APNS_PRIVATE_KEY_PATH=
APNS_BUNDLE_ID=ai.manaflow.cmux
# Set to "1" to use the APNs production environment, otherwise sandbox.
APNS_PRODUCTION=
